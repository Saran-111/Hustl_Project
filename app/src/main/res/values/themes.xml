<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Hustl" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/hustl_green</item>
        <item name="colorPrimaryVariant">@color/hustl_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/hustl_green</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Hustl.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">@color/hustl_green</item>
        <item name="android:windowBackground">@color/hustl_green</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
